            "includeHistory": false,
            "doNotWriteToContext": true,
            "systemPrompt": "Use the available tools to retrieve information and return the requested result. Use the visible context first. Use getTavily and getWebpage for research, getYoutube for YouTube summaries or creator lookups, and getLocation for route searches, route planning, and place lookups. Do not ask clarifying questions when the available evidence is enough to proceed.",
            "tools": [
