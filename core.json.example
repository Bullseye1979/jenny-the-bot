    "webpage-graph-auth": {
      "flow": [
        "webpage"
      ],
      "port": 3124,
      "auth": {
        "tenantId": "SECRET:graph_tenant_id",
        "clientId": "SECRET:graph_client_id",
        "clientSecret": "SECRET:graph_client_secret",
        "redirectUri": "https://YOUR_DOMAIN/graph-auth/callback",
        "scope": "offline_access User.Read Mail.Read Mail.ReadWrite Mail.Send Files.ReadWrite.All Sites.ReadWrite.All"
      }
    },
    "cron-graph-token-refresh": {
      "flow": [
        "cron"
      ],
      "auth": {
        "tenantId": "SECRET:graph_tenant_id",
        "clientId": "SECRET:graph_client_id",
        "clientSecret": "SECRET:graph_client_secret"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-spotify-auth": {
      "flow": [
        "webpage"
      ],
      "port": 3125,
      "auth": {
        "clientId": "SECRET:spotify_client_id",
        "clientSecret": "SECRET:spotify_client_secret",
        "redirectUri": "https://YOUR_DOMAIN/spotify-auth/callback",
        "scope": "user-read-playback-state user-modify-playback-state user-read-currently-playing playlist-read-private playlist-read-collaborative playlist-modify-public playlist-modify-private"
      }
    },
    "cron-spotify-token-refresh": {
      "flow": [
        "cron"
      ],
      "auth": {
        "clientId": "SECRET:spotify_client_id",
        "clientSecret": "SECRET:spotify_client_secret"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-chatgpt-auth": {
      "__description": "ChatGPT / OpenAI OAuth2 per-user token management. Users connect at /chatgpt-auth. Requires port 3126 in webpage.ports and webpage-auth.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3126,
      "auth": {
        "authUrl": "https://auth.openai.com/authorize",
        "tokenUrl": "https://auth.openai.com/oauth/token",
        "clientId": "YOUR_OPENAI_OAUTH_CLIENT_ID",
        "clientSecret": "YOUR_OPENAI_OAUTH_CLIENT_SECRET",
        "redirectUri": "https://YOUR_DOMAIN/chatgpt-auth/callback",
        "scope": "openid offline_access model.request"
      }
    },
    "cron-chatgpt-token-refresh": {
      "__description": "Refreshes expiring ChatGPT OAuth tokens from chatgpt_tokens table. Add a cron job entry with flow 'cron-chatgpt-token-refresh'.",
      "flow": [
        "cron"
      ],
      "auth": {
        "tokenUrl": "https://auth.openai.com/oauth/token",
        "clientId": "YOUR_OPENAI_OAUTH_CLIENT_ID",
        "clientSecret": "YOUR_OPENAI_OAUTH_CLIENT_SECRET"
      },
      "refreshBufferMinutes": 10
    },
    "core-ai-chatgpt": {
      "__description": "AI completions using per-user ChatGPT OAuth tokens. Activated when useAiModule='chatGPT' on a channel. Falls back to authPageUrl if the user has no connected token.",
      "flow": [
        "discord",
        "discord-voice",
        "api"
      ],
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o",
      "authPageUrl": "/chatgpt-auth"
    },
