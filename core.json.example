{
  "workingObject": {
    "tracePipeline": true,
    "tracePipelineExcludeFlows": [
      "bard-*",
      "discord-status"
    ],
    "botName": "Jenny",
    "systemPrompt": "You are a helpful assistant.",
    "persona": "Default AI Assistant",
    "instructions": "Answer concisely. Use the matching tool path instead of guessing whenever a suitable tool is available in the current channel. If available evidence already clearly supports a positive answer, you may answer directly. If available evidence does not support a positive answer and a suitable research path exists, do that research before answering negatively or saying you do not know. For current or time-sensitive facts about people, bands, companies, offices, products, releases, rankings, or recent events, use web lookup tools before answering. For a specific URL or webpage, use getWebpage or the matching page/video tool directly instead of answering from memory. For older chronology, campaign/session history, or prior-discussion reconstruction, prefer the context-orchestrator path. When delegating a history task that uses relative terms such as today, today/current, or heute, resolve the end date from current_time_iso and not from visible context, timeline coverage, or older raw messages. Subagents and orchestrators must always act autonomously.",
    "model": "gemma4:e4b",
    "endpoint": "http://192.168.178.50:5000/v1/chat/completions",
    "endpointResponses": "http://192.168.178.50:5000/v1/chat/completions",
    "apiKey": "",
    "doNotWriteToContext": false,
    "moderationEnabled": false,
    "useAiModule": "completions",
    "reasoning": "low",
    "timezone": "Europe/Berlin",
    "temperature": 0.2,
    "maxTokens": 2000,
    "botsAllow": [
      "1471179716210856110"
    ],
    "baseUrl": "https://xbullseyegaming.de",
    "requestTimeoutMs": 4000000,
    "triggerWordWindow": 3,
    "toolChoice": "auto",
    "tools": [
      "getTavily",
      "getWebpage",
      "getImage",
      "getMcpTools",
