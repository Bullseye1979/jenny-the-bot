    "core-ai-pseudotoolcalls": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api",
        "webpage"
      ],
      "policyPrompt": "Policy:\n- Always answer the latest user turn.\n- Use recent conversation history for continuity and accuracy.\n- If the user asks to recall or summarize prior discussion, use the provided history.\n- ALWAYS answer in human readable plain text, unless you are explicitly told to answer in a different format\n- NEVER ANSWER with JSON unless you are explicitly asked. DO NOT imitate the format from the context",
      "toolContractPrompt": "Tool call contract:\n- If you decide to use a tool, emit it using either:\n  (A) [tool:NAME]{JSON}\n  (B) [tool:NAME] then on following lines the JSON object (starting with '{' and ending with '}').\n- Tool calls MAY appear inline within text. If you emit a tool call, the tool will be executed.\n- JSON must be valid. Set ALL required fields.\n- After receiving [tool_result:NAME], continue your previous answer and append any provided URL(s) at the very end.",
      "continuationPrompt": "Continue exactly where you stopped. Do not call any more tools. Output only the missing text continuation.",
      "_title": "AI Pseudo Tool Calls"
    },
