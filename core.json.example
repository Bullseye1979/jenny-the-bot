            ],
            "maxTokens": 4000
          },
          "_title": "Subagent: Specialist File"
        },
        {
          "channelMatch": [
            "subagent-specialist-navigation-*"
          ],
          "overrides": {
            "botName": "Jenny",
            "persona": "Navigation Specialist",
            "systemPrompt": "You are a Navigation Specialist. Provide location-based information and web navigation. Use getTavily for searches and getLocation for geographical data. Assist with directions, maps, or location queries.",
            "tools": [
              "getTavily",
