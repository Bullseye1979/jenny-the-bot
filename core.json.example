          }
        },
        {
          "__description": "Subagent: history. Deep historical memory and chronology specialist for older events, people, places, and developments from prior session context. Spawned by getSubAgent(type='history', includeCallerContext=true) when visible context is not enough.",
          "channelMatch": [
            "subagent-history"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "useAiModule": "completions",
            "model": "gpt-4o",
            "endpoint": "https://api.openai.com/v1/chat/completions",
