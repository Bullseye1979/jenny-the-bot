      "flow": [
        "webpage"
      ],
      "port": 3126,
      "basePath": "/manifests",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-subagent-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3127,
      "basePath": "/subagents",
      "orchestratorToolName": "getOrchestrator",
      "specialistToolName": "getSpecialists",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-live": {
      "__description": "Live context monitor SPA. Port 3123, /live. Shows real-time transcripts from context table; channels and fields selectable. Add 3123 to webpage.ports and webpage-auth.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3123,
      "basePath": "/live",
      "allowedRoles": [
        "admin"
      ],
      "pollIntervalMs": 2000,
      "messageLimit": 300
    },
    "webpage-graph-auth": {
      "__description": "Microsoft Graph delegated OAuth2. Users connect their MS account here. Tokens stored in graph_tokens DB table. Port 3124, /graph-auth.",
      "flow": [
        "webpage"
      ],
      "port": 3124,
      "auth": {
        "tenantId": "MS_TENANT_ID",
        "clientId": "MS_CLIENT_ID",
        "clientSecret": "MS_CLIENT_SECRET",
        "redirectUri": "https://jenny.ralfreschke.de/graph-auth/callback",
        "scope": "offline_access User.Read Mail.ReadWrite Mail.Send Files.ReadWrite.All Sites.ReadWrite.All"
      }
    },
    "cron-graph-token-refresh": {
      "__description": "Refreshes expiring Microsoft Graph tokens every 5 minutes.",
      "flow": [
        "cron-graph-token-refresh"
      ],
      "auth": {
        "tenantId": "MS_TENANT_ID",
        "clientId": "MS_CLIENT_ID",
        "clientSecret": "MS_CLIENT_SECRET"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-spotify-auth": {
      "__description": "Spotify delegated OAuth2. Users connect their Spotify account here. Tokens stored in spotify_tokens DB table. Port 3125, /spotify-auth.",
      "flow": [
        "webpage"
      ],
      "port": 3125,
      "auth": {
        "clientId": "SPOTIFY_CLIENT_ID",
        "clientSecret": "SPOTIFY_CLIENT_SECRET",
        "redirectUri": "https://jenny.ralfreschke.de/spotify-auth/callback",
        "scope": "user-read-playback-state user-modify-playback-state user-read-currently-playing playlist-read-private playlist-read-collaborative playlist-modify-public playlist-modify-private"
      }
    },
    "cron-spotify-token-refresh": {
      "__description": "Refreshes expiring Spotify tokens every 5 minutes.",
      "flow": [
        "cron-spotify-token-refresh"
      ],
      "auth": {
        "clientId": "SPOTIFY_CLIENT_ID",
        "clientSecret": "SPOTIFY_CLIENT_SECRET"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-channel-config-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3129,
      "basePath": "/channels",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-oauth-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3130,
      "basePath": "/oauth",
      "roles": [
        "admin"
      ]
    },
    "webpage-oauth-connections": {
      "flow": [
        "webpage"
      ],
      "port": 3131,
      "redirectUriBase": "https://jenny.ralfreschke.de/connections",
      "roles": [
        "member",
        "admin"
      ]
    },
    "webpage-oauth-exposure": {
      "flow": [
        "webpage"
      ],
      "port": 3132,
      "toolName": "getOauthProviders",
      "roles": [
        "admin"
      ]
    },
    "webpage-bearer-exposure": {
      "flow": [
        "webpage"
      ],
      "port": 3133,
      "toolName": "getApiBearers",
      "roles": [
        "admin"
      ]
    },
    "mcp": {
      "stdio": false,
      "http": {
        "enabled": true,
        "port": 3100,
        "path": "/mcp"
      }
    }
  }
}
