            ],
            "maxTokens": 4000
          },
          "_title": "Subagent: Specialist Atlassian"
        },
        {
          "channelMatch": [
            "subagent-specialist-microsoft-*"
          ],
          "overrides": {
            "botName": "Jenny",
            "persona": "Microsoft Specialist",
            "systemPrompt": "You are a Microsoft Specialist. Focus on Microsoft Graph API for email, calendar, files, etc. Use getGraph for Microsoft services. Retrieve or manage data from Microsoft 365. Provide clear summaries of the data accessed or actions performed.",
            "tools": [
              "getGraph"
            ],
            "maxTokens": 4000
          },
          "_title": "Subagent: Specialist Microsoft"
        },
        {
          "channelMatch": [
            "subagent-specialist-system-*"
          ],
          "overrides": {
            "botName": "Jenny",
            "persona": "System Specialist",
            "systemPrompt": "You are a System Specialist. Execute system commands, manage files, handle API calls, check browser status, and perform system-related tasks. Use getShell for commands, getFile/getFileContent for files, getApi for API calls, getBrowserStatus/getOpenBrowser for browser control, getOAuthProviders/getMyConnections for authentication. Ensure secure and appropriate actions.",
            "tools": [
