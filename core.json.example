    "webpage-keymanager": {
      "__description": "Admin UI for managing API secrets (placeholder → real value). Port 3122, /key-manager. Add 3122 to webpage.ports and webpage-auth.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3122,
      "basePath": "/key-manager",
      "allowedRoles": [
        "admin"
      ]
    },
    "bard": {
      "__description": "Bard bot — second Discord bot that plays D&D mood music in voice channels",
      "flow": [],
      "token": "BARD_DISCORD",
      "musicDir": "assets/bard",
      "idlePresence": "Waiting for adventure...",
      "pollIntervalMs": 30000
    },
    "bard-cron": {
      "__description": "Label generation cron module. Inherits endpoint/apiKey/model from workingObject defaults if not set here.",
      "flow": [
        "bard-label-gen"
      ]
    },
    "bard-label-output": {
      "__description": "Writes AI-generated mood labels to the registry after each bard-label-gen run.",
      "flow": [
        "bard-label-gen"
      ]
    },
    "webpage-bard": {
      "__description": "Bard music manager SPA (upload, tag, delete tracks). Requires port 3114 in webpage.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3114,
      "allowedRoles": [],
      "label": "🎵 Bard"
    },
    "webpage-bard-stream": {
      "__description": "Browser audio player for the live Bard stream. Requires port 3116 in webpage.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3116,
      "allowedRoles": [],
      "label": "🎶 Bard Stream"
    },
    "webpage-voice": {
      "__description": "Browser voice interface (always-on mic + meeting recorder). Requires port 3119 in webpage.ports. Add reverse_proxy /voice* localhost:3119 to your Caddyfile.",
      "flow": [
        "webpage"
      ],
      "port": 3119,
      "basePath": "/voice",
      "silenceTimeoutMs": 2500,
      "silenceRmsThreshold": 0.015,
      "maxDurationMs": 30000,
      "allowedRoles": [],
      "channels": [
        {
          "__description": "Add one entry per channel you want in the voice interface dropdown",
          "id": "YOUR_CHANNEL_ID",
          "label": "General"
        }
      ],
      "clearContextChannels": []
    },
    "webpage-voice-add-context": {
      "__description": "Writes each always-on voice turn to the context DB. One DB entry per speaker paragraph. Does NOT purge context — purging is only done when applying a meeting transcript (00047 Apply button) or via POST /voice/record (00027), so follow-up voice questions about a stored transcript continue to work.",
      "flow": [
        "webpage"
      ]
    },
    "webpage-voice-output": {
      "__description": "Sends TTS MP3 audio back to the browser voice caller. Must be active in webpage flow.",
      "flow": [
        "webpage"
      ]
    },
    "webpage-voice-record": {
      "__description": "Handles POST /voice/record — full meeting recording: transcribes with Whisper, optionally diarizes with GPT, stores transcript in context DB. clearContextChannels lists channel IDs whose non-frozen context is purged before each transcript is stored (start-of-session mode). Port must match webpage-voice (default 3119).",
      "flow": [
        "webpage"
      ],
      "port": 3119,
      "allowedRoles": [
        "member",
        "admin"
      ],
      "clearContextChannels": []
    },
    "core-voice-transcribe": {
      "__description": "Source-agnostic transcription module. Active in discord-voice and webpage flows. transcribeModelDiarize is used automatically when wo.transcribeOnly=true (meeting recorder). overlapDurationS controls the overlap between chunks used for cross-chunk speaker stitching.",
      "flow": [
        "discord-voice",
        "webpage"
      ],
      "transcribeModel": "gpt-4o-mini-transcribe",
      "transcribeModelDiarize": "gpt-4o-transcribe-diarize",
      "chunkDurationS": 300,
      "overlapDurationS": 60,
      "transcribeLanguage": "",
      "transcribeEndpoint": "",
      "transcribeApiKey": ""
    },
    "core-channel-config": {
      "__description": "Optional per-channel overrides — leave channels array empty to disable, or add entries as shown below",
      "flow": [
        "discord",
        "discord-voice",
        "discord-admin",
        "discord-status",
        "api",
        "bard-label-gen",
        "webpage"
      ],
      "channels": [
        {
          "__description": "Example: a channel with custom settings — replace DISCORD_CHANNEL_ID_HERE",
          "channelMatch": [
            "DISCORD_CHANNEL_ID_HERE"
          ],
          "overrides": {
            "botName": "Jenny",
            "systemPrompt": "You are a helpful assistant.",
            "instructions": "Answer clearly and concisely.",
            "trigger": "",
            "temperature": 0.3,
            "contextSize": 30,
            "tools": [
              "getGoogle",
              "getWebpage",
              "getImage",
              "getTime",
              "getHistory"
            ]
          }
        },
        {
          "__description": "Bard label-gen: isolated entry — channelID 'bard-label-gen' is a synthetic ID set on the cron job, not a real Discord channel. Keeps bard AI params separate from any Discord channel config.",
          "channelMatch": [
            "bard-label-gen"
          ],
          "overrides": {},
          "flows": [
            {
              "flowMatch": [
                "bard-label-gen"
              ],
              "overrides": {
                "model": "gpt-4o-mini",
                "temperature": 0.3,
                "maxTokens": 60
              }
            }
          ]
        },
        {
          "__description": "Browser extension channel — used by the Jenny Edge/Chrome extension",
          "channelMatch": [
            "browser-extension"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "botName": "Jenny",
            "persona": "You are Jenny, a browser extension assistant. You help users summarize web pages and YouTube videos, and answer questions about page content.",
            "systemPrompt": "Use fetched page content as the source of truth.",
            "instructions": "Answer in full sentences. Answer only in English. When given a URL, use getWebpage or getYoutube to fetch and summarize the content. Check at least one source. Write how you came to your conclusion. Do not give out unverified information.",
            "contextSize": 70,
            "channelIds": []
          }
        },
        {
          "__description": "Subagent: resume — dedicated route for project resume/follow-up calls. Spawned by getSubAgent(projectId=..., type='resume').",
          "channelMatch": [
            "subagent-resume"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "useAiModule": "completions",
            "model": "gpt-4o-mini",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "apiKey": "OPENAI",
            "temperature": 0.2,
            "maxTokens": 4000,
            "maxLoops": 10,
            "includeHistory": true,
            "doNotWriteToContext": true,
            "systemPrompt": "Continue the existing project context exactly from where it left off and perform only the requested follow-up task. If delegation is required, never spawn type resume as a child. Choose a specialized non-resume type instead.",
            "tools": [
              "getGoogle",
              "getTavily",
              "getWebpage",
              "getHistory",
              "getYoutube",
              "getImage",
              "getImageDescription",
              "getTime",
              "getToken",
              "getLocation"
            ],
            "persona": "You are the Resume Subagent. Your task is to continue an existing project exactly from its saved context.",
            "instructions": "Honor the caller instructions for language, style, verbosity, length, and formatting. If no caller instructions are present, answer in clear concise English."
          }
        },
        {
          "__description": "Subagent: history. Deep historical memory and chronology specialist for older events, people, places, and developments from prior session context. Spawned by getSubAgent(type='history', includeCallerContext=true) when visible context is not enough.",
          "channelMatch": [
            "subagent-history"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "useAiModule": "completions",
            "model": "gpt-4o",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "apiKey": "OPENAI",
            "temperature": 0.2,
            "maxTokens": 4000,
            "maxLoops": 10,
            "maxToolCalls": 8,
            "includeHistory": true,
            "includeHistoryTools": false,
            "contextSize": 70,
            "compressedContextElements": 30,
            "doNotWriteToContext": true,
            "systemPrompt": "Use the loaded caller context and timeline blocks as your primary evidence. If the loaded context already answers the question with enough depth, answer directly and do not call tools. If the visible context is missing key details, uncertain, or would only support a shallow answer, use getInformation to identify the relevant older period and then use getHistory with the returned timeframe to retrieve deeper surrounding records. Do not spawn another history subagent.",
            "tools": [
              "getInformation",
              "getHistory",
              "getTime",
              "getSubAgent"
            ],
            "persona": "You are the History Subagent. Your task is to reconstruct older session knowledge, chronology, people, places, and developments for the caller.",
            "instructions": "Honor the caller instructions for language, style, verbosity, length, and formatting. If no caller instructions are present, answer in clear concise English."
          }
        },
        {
          "__description": "Subagent: research. Handles web research, webpage fetches, YouTube, route searches, route planning, and location lookups. Spawned by getSubAgent(type='research').",
          "channelMatch": [
            "subagent-research"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "useAiModule": "completions",
            "model": "gpt-4o-mini",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "apiKey": "OPENAI",
            "temperature": 0.2,
            "maxTokens": 4000,
            "maxLoops": 10,
            "includeHistory": false,
            "doNotWriteToContext": true,
            "systemPrompt": "Use the available tools to retrieve information and return the requested result. Use the visible context first. Use getTavily and getWebpage for research, getYoutube for YouTube summaries or creator lookups, and getLocation for route searches, route planning, and place lookups. Do not ask clarifying questions when the available evidence is enough to proceed.",
            "tools": [
              "getTavily",
              "getWebpage",
              "getYoutube",
              "getLocation",
              "getTime"
            ],
            "persona": "You are the Research Subagent. Your task is to investigate web, route, location, and source questions for the caller.",
            "instructions": "Honor the caller instructions for language, style, verbosity, length, and formatting. If no caller instructions are present, answer in clear concise English."
          }
        },
        {
          "__description": "Subagent: media. Handles image generation, animation, video, and media analysis. Spawned by getSubAgent(type='media').",
          "channelMatch": [
            "subagent-media"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "useAiModule": "completions",
            "model": "gpt-4o-mini",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "apiKey": "OPENAI",
            "temperature": 0.2,
            "maxTokens": 4000,
            "maxLoops": 6,
            "includeHistory": false,
            "doNotWriteToContext": true,
            "systemPrompt": "Create or analyze the requested media assets. Base the result only on the generated or retrieved content and do not invent details.",
            "tools": [
              "getImage",
              "getAnimatedPicture",
              "getVideoFromText",
              "getImageDescription",
              "getToken",
              "getZIP"
            ],
            "persona": "You are the Media Subagent. Your task is to create, transform, and analyze media assets for the caller.",
            "instructions": "Honor the caller instructions for language, style, verbosity, length, and formatting. If no caller instructions are present, answer in clear concise English."
          }
        },
        {
          "__description": "Subagent: generic. General-purpose fallback when no specialist fits better. Spawned by getSubAgent(type='generic').",
          "channelMatch": [
            "subagent-generic"
          ],
          "overrides": {
            "apiEnabled": 1,
            "apiSecret": "API_SECRET",
            "useAiModule": "completions",
            "model": "gpt-4o-mini",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "apiKey": "OPENAI",
            "temperature": 0.3,
            "maxTokens": 4000,
            "maxLoops": 10,
            "includeHistory": false,
            "doNotWriteToContext": true,
            "systemPrompt": "Complete the assigned task using the available tools. Reuse existing project context when it is already loaded and do not invent missing facts.",
            "tools": [
              "getGoogle",
              "getTavily",
              "getWebpage",
              "getHistory",
              "getYoutube",
              "getImage",
              "getImageDescription",
              "getTime",
              "getToken",
              "getLocation"
            ],
            "persona": "You are the Generic Subagent. Your task is to complete assigned work that does not fit a more specific specialist.",
            "instructions": "Honor the caller instructions for language, style, verbosity, length, and formatting. If no caller instructions are present, answer in clear concise English."
          }
        },
        {
          "__description": "Subagent: image prompt enhancer — used by getImage tool to improve prompts before generation.",
          "channelMatch": [
            "subagent-img-enhance"
          ],
          "overrides": {
            "systemPrompt": "You are a Stable Diffusion prompt enhancer. Given a basic prompt, output an improved, detailed prompt optimized for image generation. Output ONLY the enhanced prompt text, no explanations.",
            "model": "gpt-4o-mini",
            "maxTokens": 350,
            "temperature": 0.7,
            "tools": [],
            "apiEnabled": 1,
            "apiSecret": "API_SECRET"
          }
        },
        {
          "__description": "Subagent: webpage summary — used by getWebpage tool to summarize fetched page content.",
          "channelMatch": [
            "subagent-webpage-summary"
          ],
          "overrides": {
            "systemPrompt": "You summarize web page content concisely and accurately. Focus on the key information. Output plain text only.",
            "model": "gpt-4o-mini",
            "maxTokens": 1400,
            "temperature": 0.1,
            "tools": [],
            "apiEnabled": 1,
            "apiSecret": "API_SECRET"
          }
        }
      ]
    },
    "webpage-graph-auth": {
      "flow": [
        "webpage"
      ],
      "port": 3124,
      "auth": {
        "tenantId": "SECRET:graph_tenant_id",
        "clientId": "SECRET:graph_client_id",
        "clientSecret": "SECRET:graph_client_secret",
        "redirectUri": "https://YOUR_DOMAIN/graph-auth/callback",
        "scope": "offline_access User.Read Mail.Read Mail.ReadWrite Mail.Send Files.ReadWrite.All Sites.ReadWrite.All"
      }
    },
    "cron-graph-token-refresh": {
      "flow": [
        "cron"
      ],
      "auth": {
        "tenantId": "SECRET:graph_tenant_id",
        "clientId": "SECRET:graph_client_id",
        "clientSecret": "SECRET:graph_client_secret"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-spotify-auth": {
      "flow": [
        "webpage"
      ],
      "port": 3125,
      "auth": {
        "clientId": "SECRET:spotify_client_id",
        "clientSecret": "SECRET:spotify_client_secret",
        "redirectUri": "https://YOUR_DOMAIN/spotify-auth/callback",
        "scope": "user-read-playback-state user-modify-playback-state user-read-currently-playing playlist-read-private playlist-read-collaborative playlist-modify-public playlist-modify-private"
      }
    },
    "cron-spotify-token-refresh": {
      "flow": [
        "cron"
      ],
      "auth": {
        "clientId": "SECRET:spotify_client_id",
        "clientSecret": "SECRET:spotify_client_secret"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-chatgpt-auth": {
      "__description": "ChatGPT / OpenAI OAuth2 per-user token management. Users connect at /chatgpt-auth. Requires port 3126 in webpage.ports and webpage-auth.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3126,
      "auth": {
        "authUrl": "https://auth.openai.com/authorize",
        "tokenUrl": "https://auth.openai.com/oauth/token",
        "clientId": "YOUR_OPENAI_OAUTH_CLIENT_ID",
        "clientSecret": "YOUR_OPENAI_OAUTH_CLIENT_SECRET",
        "redirectUri": "https://YOUR_DOMAIN/chatgpt-auth/callback",
        "scope": "openid offline_access model.request"
      }
    },
    "cron-chatgpt-token-refresh": {
      "__description": "Refreshes expiring ChatGPT OAuth tokens from chatgpt_tokens table. Add a cron job entry with flow 'cron-chatgpt-token-refresh'.",
      "flow": [
        "cron"
      ],
      "auth": {
        "tokenUrl": "https://auth.openai.com/oauth/token",
        "clientId": "YOUR_OPENAI_OAUTH_CLIENT_ID",
        "clientSecret": "YOUR_OPENAI_OAUTH_CLIENT_SECRET"
      },
      "refreshBufferMinutes": 10
    },
    "core-ai-chatgpt": {
      "__description": "AI completions using per-user ChatGPT OAuth tokens. Activated when useAiModule='chatGPT' on a channel. Falls back to authPageUrl if the user has no connected token.",
      "flow": [
        "discord",
        "discord-voice",
        "api"
      ],
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o",
      "authPageUrl": "/chatgpt-auth"
    },
    "webpage-manifests": {
      "flow": [
        "webpage"
      ],
      "port": 3126,
      "basePath": "/manifests",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-subagent-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3127,
      "basePath": "/subagents",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-timeline": {
      "flow": [
        "webpage"
      ],
      "port": 3128,
      "basePath": "/timeline",
      "allowedRoles": [
        "admin"
      ]
    },
    "discord-subagent-poll": {
      "__description": "Polls the registry for completed async subagent jobs and delivers results to the originating Discord channel. Set enabled:true to activate. pollIntervalMs: how often to check (ms). callerFlowPattern: flow name prefixes that trigger delivery. maxJobAgeMs: running jobs older than this are expired as errors.",
      "enabled": false,
      "pollIntervalMs": 5000,
      "callerFlowPattern": [
        "discord",
        "discord-voice"
      ],
      "maxJobAgeMs": 86400000
    },
    "webpage-subagent-poll": {
      "__description": "Polls the registry for completed async subagent jobs whose callerFlow starts with 'webpage' and delivers results via SSE to the originating webpage client. Requires GET /api/async-results/stream?channelID=<callerChannelId> to be open on the client side. Set enabled:true to activate.",
      "enabled": false,
      "pollIntervalMs": 5000,
      "maxJobAgeMs": 86400000
    },
    "webpage-channel-config-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3129,
      "basePath": "/channels",
      "allowedRoles": [
        "admin"
      ]
    }
  }
}
