    "discord-subagent-poll": {
      "__description": "Polls the registry for completed async subagent jobs and delivers results to the originating Discord channel. Set enabled:true to activate. pollIntervalMs: how often to check (ms). callerFlowPattern: flow name prefixes that trigger delivery. maxJobAgeMs: running jobs older than this are expired as errors.",
      "enabled": false,
      "pollIntervalMs": 5000,
      "callerFlowPattern": [
        "discord",
        "discord-voice"
      ],
      "maxJobAgeMs": 86400000
    },
    "webpage-subagent-poll": {
      "__description": "Polls the registry for completed async subagent jobs whose callerFlow starts with 'webpage' and delivers results via SSE to the originating webpage client. Requires GET /api/async-results/stream?channelID=<callerChannelId> to be open on the client side. Set enabled:true to activate.",
      "enabled": false,
      "pollIntervalMs": 5000,
      "maxJobAgeMs": 86400000
    },
    "webpage-channel-config-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3129,
      "basePath": "/channels",
      "allowedRoles": [
        "admin"
      ]
    }
  }
}
