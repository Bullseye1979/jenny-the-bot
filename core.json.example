    "core-voice-tts": {
      "__description": "Text-to-speech synthesis for voice responses. Inherits tts* keys from workingObject if not set here.",
      "flow": [
        "discord-voice",
        "webpage"
      ],
      "ttsModel": "gpt-4o-mini-tts",
      "ttsVoice": "nova",
      "ttsEndpoint": "https://api.openai.com/v1/audio/speech",
      "ttsApiKey": "OPENAI",
      "ttsFormat": "opus",
      "ttsFetchTimeoutMs": 30000
    },
    "webpage-channel-config-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3129,
      "basePath": "/channels",
      "allowedRoles": [
        "admin"
      ]
    },
    "mcp": {
      "__description": "MCP (Model Context Protocol) server. Exposes all tool manifests as MCP tools. Enable stdio for Claude Desktop / Cursor. Enable http for network-accessible clients.",
      "apiSecret": "JENNY_MCP_TOKEN",
      "stdio": false,
      "http": {
        "enabled": false,
        "port": 3100,
        "path": "/mcp"
      }
    },
    "core-channel-gate": {
      "flow": [
        "discord",
        "discord-voice",
        "discord-admin",
        "api"
      ]
    },
    "core-trigger-gate": {
      "flow": [
        "discord",
        "discord-voice"
      ]
    },
    "core-ai-context-loader": {
      "__description": "Preloads context snapshot before AI completions. Runs on all AI flows.",
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api",
        "bard-label-gen"
      ]
    },
    "core-ai-context-writer": {
      "__description": "Persists queued context turns after AI completions.",
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api",
        "bard-label-gen"
      ]
    },
    "discord-purge": {
      "__description": "Handles !purge (DM) and /purge (slash command) to bulk-delete messages.",
      "flow": [
        "discord",
        "discord-admin"
      ]
    },
    "discord-voice-tts-play": {
      "__description": "Plays TTS audio segments into the active Discord voice channel.",
      "flow": [
        "discord-voice"
      ]
    },
    "webpage-voice-transcribe-gate": {
      "__description": "Validates voice transcription payloads on the webpage flow before processing.",
      "flow": [
        "webpage"
      ]
    }
  }
}
