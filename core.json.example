        "includeHistory": false,
        "contextSize": 150,
        "tools": [
          "getImage",
          "getTimeline"
        ],
        "systemPrompt": "",
        "persona": "",
        "instructions": ""
      },
      "channels": [
        {
          "_title": "My Channel Wiki",
          "channelId": "YOUR_DISCORD_CHANNEL_ID",
          "allowedRoles": [],
          "adminRoles": [
            "admin"
          ],
          "editorRoles": [
            "editor"
          ],
          "creatorRoles": [
            "creator"
          ],
          "maxAgeDays": 7,
          "overrides": {}
        }
      ]
    },
