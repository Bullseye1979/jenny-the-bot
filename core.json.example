    "webpage-bard": {
      "flow": [
        "webpage"
      ],
      "port": 3114,
      "basePath": "/bard",
      "allowedRoles": [
        "admin",
        "dnd"
      ],
      "adminRoles": [
        "admin",
        "dnd"
      ],
      "autoTag": {
        "enabled": true,
        "tavilyApiKey": "TAVILY",
        "tavilyMaxResults": 5,
        "tavilyTimeoutMs": 15000,
        "endpoint": "http://192.168.178.50:5000/v1/chat/completions",
        "apiKey": "",
        "model": "gemma4:e4b",
        "temperature": 0.2,
        "maxTokens": 200,
        "llmTimeoutMs": 604800000,
        "systemPrompt": "You are a music tagging assistant for a tabletop RPG (D&D) ambient music library.\nAssign exactly 5 tags to a music track.\nEach tag must be a single lowercase word (only a-z, 0-9, hyphens allowed).\nThe first word is the location, where this music fits best (e.g. battlefield, tavern, city).\nThe second word is the situation, where this music fits best (e.g. battle, party, grieving)\nThe next three words describe the mood that the music transports (e.g. sad, joy, happy).\nIMPORTANT: The words used in the examples are just examples, use words from already existing list, if fitting. Only if no other word fits, create a new one.\nOutput ONLY a JSON array of exactly 5 strings (1 location, 1 situation, 3 moods). No explanation, no extra text.\nExample: [\"battlefield\",\"battle\",\"epic\",\"joy\",\"relieved\"]",
        "userPrompt": "Track title: \"{title}\"\n\nWeb search results for this track:\n{tavilySnippet}\n\nExisting tags already used in this library (prefer these when applicable):\n{existingTags}\n\nAssign exactly 5 tags. Output only a JSON array of 5 strings.",
        "_title": "Auto-Tagging (AI)",
        "endpointResponses": "http://192.168.178.50:5000/v1/chat/completions",
        "requestTimeoutMs": 604800000,
        "useAiModule": "completions",
        "fallbackOverrides": {
          "endpoint": "https://api.openai.com/v1/chat/completions",
          "endpointResponses": "https://api.openai.com/v1/chat/completions",
          "apiKey": "OPENAI",
          "model": "gpt-4o",
          "useAiModule": "completions"
        }
