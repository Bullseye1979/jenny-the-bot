    "core-ai-completions": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api",
        "bard-label-gen",
        "webpage"
      ],
      "policyPrompt": "Policy:\n- Do not answer unrelated older user requests.\n- If the latest user message asks you to continue your previous response, continue exactly where you stopped — do not repeat, summarize, or restart.\n- If tools are available, use them only when necessary.\n- When you emit a tool call, do not include extra prose in the same turn.\n- When including a URL in your response, always use a descriptive markdown link: [title](url). Never use the bare URL as the link text.\n- ALWAYS answer in human readable plain text, unless you are explicitly told to answer in a different format",
      "_title": "AI Completions"
    },
    "core-ai-responses": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api",
        "webpage"
      ],
      "policyPrompt": "Policy:\n- NEVER ANSWER TO OLDER USER REQUESTS\n- Use tools only when necessary.\n- When you emit a tool call, do not include extra prose in the same turn.\n- ALWAYS answer in human readable plain text, unless explicitly told to use a different format.",
      "_title": "AI Responses"
    },
