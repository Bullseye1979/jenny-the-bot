{
  "__description": "Minimal core.json for Jenny Discord AI Bot. Fill in all YOUR_* placeholders, then copy core.json.example to core.json and start the bot.",
  "workingObject": {
    "__description": "Global runtime defaults for the bot",
    "botName": "Jenny",
    "systemPrompt": "You are a helpful assistant.",
    "persona": "Helpful AI Assistant",
    "instructions": "Answer concisely and helpfully.",
    "tracePipeline": false,
    "tracePipelineExcludeFlows": [
      "webpage*",
      "bard-*"
    ],
    "moderationEnabled": false,
    "trigger": "jenny",
    "triggerWordWindow": 3,
    "model": "gpt-4o-mini",
    "endpoint": "https://api.openai.com/v1/chat/completions",
    "endpointResponses": "https://api.openai.com/v1/responses",
    "apiKey": "OPENAI",
    "useAiModule": "completions",
    "temperature": 0.2,
    "maxTokens": 2000,
    "maxLoops": 10,
    "maxToolCalls": 5,
    "toolChoice": "auto",
    "requestTimeoutMs": 120000,
    "tools": [
      "getImage",
      "getImageDescription",
      "getImageSD",
      "getAnimatedPicture",
      "getVideoFromText",
      "getTime",
      "getToken",
      "getLocation",
      "getBan",
      "getSubAgent"
    ],
    "includeHistory": true,
    "includeHistoryTools": false,
    "includeRuntimeContext": true,
    "detailedContext": true,
    "contextTokenBudget": 60000,
    "contextSize": 20,
    "doNotWriteToContext": false,
    "modAdmin": "YOUR_DISCORD_USER_ID",
    "modSilence": "[silence]",
    "apiSecret": "API_SECRET",
    "apiEnabled": 1,
    "botsAllow": [],
    "showReactions": true,
    "allowArtifactGeneration": true,
    "__NOTE_allowArtifactGeneration": "NOT YET IMPLEMENTED - reserved for future use; has no effect currently",
    "baseUrl": "YOUR_PUBLIC_SERVER_URL",
    "timezone": "Europe/Berlin",
    "response": "",
    "payload": "",
    "fileUrls": [],
    "logging": [],
    "db": {
      "__description": "MySQL connection settings",
      "host": "localhost",
      "user": "YOUR_DB_USER",
      "password": "YOUR_DB_PASSWORD",
      "database": "YOUR_DB_NAME"
    },
    "ttsModel": "gpt-4o-mini-tts",
    "ttsVoice": "nova",
    "ttsEndpoint": "https://api.openai.com/v1/audio/speech",
    "ttsApiKey": "OPENAI",
    "transcribeModel": "gpt-4o-mini-transcribe",
    "transcribeLanguage": "",
    "transcribeEndpoint": "",
    "transcribeApiKey": "OPENAI",
    "avatarApiKey": "OPENAI",
    "avatarEndpoint": "https://api.openai.com/v1/images/generations",
    "avatarModel": "dall-e-3",
    "avatarSize": "1024x1024",
    "avatarPrompt": "",
    "gdprDisclaimer": "GDPR Notice & Consent\n\nThis bot processes your Discord messages to provide AI assistant features.\n\nTo consent to text processing: /gdpr text 1\nTo consent to voice processing: /gdpr voice 1\nTo revoke consent: /gdpr text 0 or /gdpr voice 0\n\nContact the server administrator for questions.",
    "discord-admin": {
      "__description": "Slash command configuration",
      "slash": {
        "silent": true,
        "ephemeral": false,
        "definitions": [
          {
            "name": "macro",
            "description": "Manage personal text macros",
            "options": [
              {
                "type": 1,
                "name": "create",
                "description": "Create or update a macro",
                "options": [
                  {
                    "type": 3,
                    "name": "name",
                    "description": "Macro name",
                    "required": true
                  },
                  {
                    "type": 3,
                    "name": "text",
                    "description": "Macro text",
                    "required": true
                  }
                ]
              },
              {
                "type": 1,
                "name": "run",
                "description": "Run a macro",
                "options": [
                  {
                    "type": 3,
                    "name": "name",
                    "description": "Macro name",
                    "required": true
                  }
                ]
              },
              {
                "type": 1,
                "name": "list",
                "description": "List all your macros"
              },
              {
                "type": 1,
                "name": "delete",
                "description": "Delete one of your macros",
                "options": [
                  {
                    "type": 3,
                    "name": "name",
                    "description": "Macro name",
                    "required": false
                  }
                ]
              }
            ]
          },
          {
            "name": "avatar",
            "description": "Set or generate the bot's channel avatar",
            "options": [
              {
                "type": 1,
                "name": "url",
                "admin": [
                  "YOUR_DISCORD_USER_ID"
                ],
                "description": "Download image from a URL and set as avatar",
                "options": [
                  {
                    "type": 3,
                    "name": "url",
                    "description": "Direct image URL",
                    "required": true
                  }
                ]
              },
              {
                "type": 1,
                "name": "prompt",
                "admin": [
                  "YOUR_DISCORD_USER_ID"
                ],
                "description": "Generate avatar from prompt",
                "options": [
                  {
                    "type": 3,
                    "name": "text",
                    "description": "Prompt text",
                    "required": true
                  }
                ]
              },
              {
                "type": 1,
                "name": "regen",
                "admin": [
                  "YOUR_DISCORD_USER_ID"
                ],
                "description": "Regenerate avatar using current prompt"
              }
            ]
          },
          {
            "name": "purge",
            "description": "Delete recent messages",
            "admin": [
              "YOUR_DISCORD_USER_ID"
            ],
            "options": [
              {
                "type": 4,
                "name": "count",
                "description": "How many (max 5000)",
                "required": false
              }
            ]
          },
          {
            "name": "purgedb",
            "description": "Delete the database entries for this channel",
            "admin": [
              "YOUR_DISCORD_USER_ID"
            ]
          },
          {
            "name": "freeze",
            "description": "Mark DB rows for this channel as frozen",
            "admin": [
              "YOUR_DISCORD_USER_ID"
            ]
          },
          {
            "name": "rebuilddb",
            "description": "Rebuild derived context tables for this channel and linked channel IDs",
            "admin": [
              "YOUR_DISCORD_USER_ID"
            ]
          },
          {
            "name": "gdpr",
            "description": "Set GDPR consent flags",
            "options": [
              {
                "type": 1,
                "name": "text",
                "description": "Enable/disable text chat consent",
                "options": [
                  {
                    "type": 4,
                    "name": "value",
                    "description": "0 or 1",
                    "required": true
                  }
                ]
              },
              {
                "type": 1,
                "name": "voice",
                "description": "Enable/disable voice consent",
                "options": [
                  {
                    "type": 4,
                    "name": "value",
                    "description": "0 or 1",
                    "required": true
                  }
                ]
              }
            ]
          },
          {
            "name": "join",
            "description": "Join my current voice channel"
          },
          {
            "name": "leave",
            "description": "Leave the current voice channel"
          },
          {
            "name": "error",
            "description": "Simulate an internal error for testing"
          },
          {
            "name": "bardjoin",
            "description": "Spawn the bard bot in your current voice channel to play mood music"
          },
          {
            "name": "bardleave",
            "description": "Remove the bard bot from the voice channel"
          },
          {
            "name": "bardstart",
            "description": "Start the bard music stream for the browser (no Discord voice join required)"
          },
          {
            "name": "bardstop",
            "description": "Stop the browser bard music stream"
          }
        ]
      }
    },
    "toolsconfig": {
      "__description": "Per-tool configuration — only fill in the tools you enable in 'tools' above",
      "getGraph": {
        "__description": "Microsoft Graph API — delegated OAuth2. Users must connect their account at /graph-auth. No credentials here.",
        "defaultSharePointHostname": "mycompany.sharepoint.com",
        "defaultMailFolderId": "inbox",
        "defaultPageSize": 25
      },
      "getSpotify": {
        "__description": "Spotify API — delegated OAuth2. Users must connect their account at /spotify-auth. No credentials here. Requires Spotify Premium for playback control."
      },
      "getGoogle": {
        "__description": "Google Custom Search — requires apiKey and cseId",
        "apiKey": "GOOGLE",
        "cseId": "GOOGLE_CSE_ID",
        "num": 5,
        "safe": "off",
        "timeoutMs": 20000
      },
      "getWebpage": {
        "__description": "Web page fetcher — routes AI summary through internal subagent API",
        "timeoutMs": 30000,
        "maxInputChars": 100000,
        "wordThreshold": 1500,
        "summaryApiUrl": "http://localhost:3400",
        "summaryChannelId": "subagent-webpage-summary",
        "summaryTimeoutMs": 45000
      },
      "getImage": {
        "__description": "DALL-E image generation — requires apiKey and publicBaseUrl",
        "apiKey": "OPENAI",
        "endpoint": "https://api.openai.com/v1/images/generations",
        "model": "dall-e-3",
        "size": "1024x1024",
        "n": 1,
        "publicBaseUrl": "YOUR_PUBLIC_SERVER_URL/",
        "targetLongEdge": 1024,
        "enhancerApiUrl": "http://localhost:3400",
        "enhancerChannelId": "subagent-img-enhance",
        "enhancerApiSecret": ""
      },
      "getTime": {
        "__description": "No API configuration required"
      },
      "getPDF": {
        "__description": "PDF generation via Puppeteer — requires publicBaseUrl",
        "publicBaseUrl": "YOUR_PUBLIC_SERVER_URL",
        "headless": "new",
        "chromeArgs": [
          "--no-sandbox"
        ],
        "waitUntil": "networkidle0",
        "timeoutMs": 120000,
        "format": "A4",
        "printBackground": true
      },
      "getText": {
        "__description": "Text file generation — requires publicBaseUrl",
        "publicBaseUrl": "YOUR_PUBLIC_SERVER_URL"
      },
      "getHistory": {
        "__description": "Hierarchical history zoom tool — each call goes exactly one level deeper and returns either child blocks or raw rows at the bottom.",
        "maxRows": 300,
        "includeToolRows": false,
        "includeJson": false
      },
      "getTimeline": {
        "__description": "Chronological timeline from derived context segments and nodes.",
        "maxEntries": 120,
        "compact": true
      },
      "getYoutube": {
        "__description": "YouTube transcript fetcher — returns raw transcript dump. LLM processing is done by the calling subagent.",
        "googleApiKey": "GOOGLE",
        "dumpThresholdChars": 40000,
        "transcriptLangs": [
          "de",
          "en"
        ],
        "searchMaxResults": 5,
        "regionCode": "DE",
        "relevanceLanguage": "de"
      },
      "getSubAgent": {
        "__description": "Routes a task to an isolated subagent channel via the internal API flow. Subagents inherit the caller instructions for language, style, verbosity, length, and formatting, so the first subagent answer is already ready for delivery without a second persona pass. Each type maps to a dedicated channelID configured in core-channel-config. Caller context is not preloaded unless the tool call sets includeCallerContext=true.",
        "apiUrl": "http://localhost:3400",
        "apiSecret": "API_SECRET",
        "timeoutMs": 120000,
        "asyncSpawnPath": "/api/spawn",
        "spawnTimeoutMs": 10000,
        "maxSpawnDepth": 2,
        "types": {
          "resume": "subagent-resume",
          "history": "subagent-history",
          "research": "subagent-research",
          "generate": "subagent-generate",
          "media": "subagent-media",
          "atlassian": "subagent-atlassian",
          "microsoft": "subagent-microsoft",
          "develop": "subagent-develop",
          "patch": "subagent-patch",
          "orchestrate": "subagent-orchestrate",
          "test": "subagent-test",
          "generic": "subagent-generic"
        }
      },
      "getImageDescription": {
        "__description": "Internal API-backed image description tool",
        "channelId": "browser-extension",
        "apiUrl": "http://localhost:3400",
        "apiSecret": "API_SECRET",
        "maxTokens": 1000,
        "timeoutMs": 60000,
        "systemPrompt": "You are an expert vision analyst. Provide faithful, useful descriptions and extract visible text.",
        "defaultPrompt": "Describe the image accurately. Extract visible text if present."
      },
      "getImageSD": {
        "__description": "Local Stable Diffusion image generation",
        "baseUrl": "http://127.0.0.1:7860",
        "publicBaseUrl": "https://yourserver.example.com",
        "size": "256x256",
        "n": 1,
        "steps": 15,
        "cfgScale": 7,
        "sampler": "Euler a",
        "seed": -1,
        "model": "realisticVisionV60B1_v51HyperVAE.safetensors",
        "negativePrompt": "worst quality, low quality, normal quality, lowres, jpeg artifacts, blurry, oversaturated, undersaturated, washed out, bad lighting, harsh lighting, overexposed, underexposed, noisy, grainy, posterized, bad anatomy, malformed anatomy, deformed, disfigured, mutated, distorted, asymmetrical, bad proportions, out of frame, cropped body, warped perspective, bad hands, bad feet, deformed hands, malformed hands, mangled hands, extra fingers, extra digits, extra limbs, extra arms, extra legs, missing fingers, fewer digits, fewer fingers, fused fingers, webbed fingers, long fingers, short fingers, broken fingers, distorted fingers, incorrect finger count, more than 5 fingers per hand, less than 5 fingers per hand, polydactyly, syndactyly, floating limbs, disconnected limbs, duplicate limbs, fused limbs, cross-eye, lazy eye, wonky eyes, deformed face, malformed face, text, watermark, signature, logo, captions, UI, interface elements, glitches, tiling, pattern artifacts, banding, moire",
        "negativeExtra": "overprocessed, muddy colors",
        "timeoutMs": 1400000,
        "networkTimeoutMs": 14400000
      }
    },
    "context": {
      "timelineSummaryPrompt": "Summarize the supplied channel segment and return strict JSON only.\nRequired JSON keys: summary.\nsummary must be a structured plain-text block stored in a single string value.\nMake the summary richer and more explicit than a short paragraph.\nUse this exact section order inside the summary string when information exists:\nOverview:\nTopics:\nKey Events:\nLocations:\nPeople:\nWrite concise but informative sentences or bullet-style lines inside those sections.\nInclude important names, places, notable discussion topics, jokes, conflicts, and key events directly in the summary text.\nDo not split those details into separate JSON fields.\nDo not use phrases such as \"in this segment\", \"in these messages\", \"the segment shows\", or similar framing.\nRemain domain-agnostic. Do not assume DnD unless the messages actually indicate it.\nDo not include markdown or any text outside the JSON object."
    }
  },
  "config": {
    "__description": "Flow wiring and module-specific configuration",
    "discord": {
      "__description": "Fill in your Discord bot token",
      "flowName": "discord",
      "token": "DISCORD",
      "intents": [
        "Guilds",
        "GuildMessages",
        "MessageContent",
        "GuildVoiceStates",
        "GuildMembers",
        "DirectMessages"
      ]
    },
    "api": {
      "__description": "HTTP API server (optional — remove this block to disable)",
      "flowName": "api",
      "host": "0.0.0.0",
      "port": 3400,
      "path": "/api",
      "publicBaseUrl": "https://xbullseyegaming.de"
    },
    "cron": {
      "__description": "Scheduled jobs (optional — leave jobs array empty to disable)",
      "flowName": "cron",
      "timezone": "Europe/Berlin",
      "tickMs": 15000,
      "jobs": [
        {
          "__description": "Bard label generation — runs every minute, updates mood labels for active sessions. channelId must match the D&D text channel so core-channel-config can apply bard-label-gen flow overrides (model, endpoint, apiKey).",
          "id": "bard-label-gen",
          "cron": "* * * * *",
          "enabled": false,
          "channelId": "YOUR_DND_TEXT_CHANNEL_ID"
        }
      ]
    },
    "context": {
      "__description": "Context engine for raw storage and derived retrieval — fill in apiKey",
      "segmentTurnCount": 6,
      "nodeBranchFactor": 4,
      "recentRawCount": 80,
      "retrievalMaxSegments": 6,
      "retrievalNeighborSegments": 1,
      "retrievalMaxNodeSummaries": 2,
      "segmentGapMinutes": 20,
      "summaryMaxLength": 320,
      "anchorEnabled": true,
      "anchorRebuildOnWrite": true,
      "anchorMinConfidence": 0.2,
      "anchorMaxEvidenceRows": 12,
      "anchorOriginDepth": 3,
      "anchorLinkedContextWeight": 0.55,
      "anchorLlmFallbackEnabled": false,
      "embeddingEnabled": true,
      "embeddingRebuildOnWrite": true,
      "embeddingMaxCandidates": 10,
      "embeddingMinScore": 0.18,
      "embeddingLinkedContextWeight": 0.5,
      "historyZoomEnabled": true,
      "historyZoomBaseSize": 100,
      "historyZoomMaxLevels": 4,
      "historyZoomLinkedContextWeight": 0.5,
      "historyZoomRebuildOnWrite": true,
      "meshEnabled": true,
      "meshRebuildOnWrite": true,
      "meshTargetMicroRows": 100,
      "meshRollupFactor": 10,
      "meshMaxLevels": 4,
      "meshEntityMinConfidence": 0.25,
      "meshGraphDepth": 2,
      "meshLinkedContextWeight": 0.5,
      "meshNeighborBlockCount": 2,
      "eventEnabled": true,
      "eventRebuildOnWrite": true,
      "eventMinConfidence": 0.28,
      "eventMaxCandidates": 8,
      "eventLinkedContextWeight": 0.45,
      "eventMinRows": 3,
      "eventMaxRows": 18,
      "eventAdaptiveGapMinutes": 12,
      "timelineChannelDenyList": [
        "cron",
        "cron-*"
      ],
      "timelineFlowDenyList": [
        "cron",
        "cron-*"
      ],
      "subchannelFallback": false,
      "rebuildOnWrite": true
    },
    "webpage": {
      "flowName": "webpage",
      "ports": [
        3000,
        3111,
        3112,
        3113,
        3114,
        3115,
        3116,
        3117,
        3118,
        3119,
        3120,
        3121,
        3122,
        3126,
        3127,
        3128,
        3129
      ]
    },
    "webpage-router": {
      "__description": "Maps HTTP port+path to a named flow and sets wo.channelId. Runs before core-channel-config so flow-specific overrides apply to web endpoints.",
      "flow": [
        "webpage"
      ],
      "routes": [
        {
          "__description": "Route /wiki requests to flow 'webpage-wiki'; channelId from first path segment after /wiki",
          "port": 3117,
          "pathPrefix": "/wiki",
          "flow": "webpage-wiki",
          "channelIdSource": "path:0"
        },
        {
          "__description": "Route /voice requests to flow 'webpage-voice'; channelId from ?channelId= query param",
          "port": 3119,
          "pathPrefix": "/voice",
          "flow": "webpage-voice",
          "channelIdSource": "query:channelId"
        }
      ]
    },
    "webpage-auth": {
      "__description": "Discord OAuth2 SSO for all web modules. The Jenny bot must be invited to every guild listed in 'guilds'. First guild where the user is a member wins. Backward compat: old top-level guildId still works.",
      "flow": [
        "webpage"
      ],
      "clientId": "YOUR_DISCORD_CLIENT_ID",
      "clientSecret": "DISCORD_CLIENT_SECRET",
      "sessionSecret": "SESSION_SECRET",
      "redirectUri": "",
      "scope": "identify guilds.members.read",
      "loginPort": 3111,
      "ports": [
        3111,
        3112,
        3113,
        3114,
        3115,
        3116,
        3117,
        3118,
        3119,
        3120,
        3121,
        3122,
        3126,
        3127,
        3128,
        3129
      ],
      "sessionMaxAgeSec": 43200,
      "sameSite": "Lax",
      "ssoPartners": [],
      "guilds": [
        {
          "guildId": "YOUR_PRIMARY_DISCORD_GUILD_ID",
          "defaultRole": "member",
          "allowRoleIds": [],
          "rolePriority": [
            "YOUR_ADMIN_ROLE_ID"
          ],
          "roleMap": {
            "YOUR_ADMIN_ROLE_ID": "admin",
            "YOUR_MEMBER_ROLE_ID": "member"
          }
        }
      ]
    },
    "webpage-menu": {
      "__description": "Global navigation menu shown on all webpage modules. Add one item per page. 'roles' is optional: omit or leave empty to show to everyone.",
      "flow": [
        "webpage"
      ],
      "items": [
        {
          "text": "Assistants\\Chat",
          "iconKey": "chat",
          "link": "/chat"
        },
        {
          "text": "Tools\\Inpainting",
          "iconKey": "inpainting",
          "link": "/inpainting"
        },
        {
          "text": "Tools\\Bard",
          "iconKey": "bard",
          "link": "/bard",
          "roles": [
            "admin"
          ]
        },
        {
          "text": "Administrator\\Config",
          "iconKey": "config",
          "link": "/config",
          "roles": [
            "admin"
          ]
        },
        {
          "text": "Administrator\\Manifests",
          "iconKey": "manifests",
          "link": "/manifests",
          "roles": [
            "admin"
          ]
        },
        {
          "text": "Administrator\\Subagents",
          "iconKey": "subagents",
          "link": "/subagents",
          "roles": [
            "admin"
          ]
        },
        {
          "text": "Administrator\\Channels",
          "iconKey": "config",
          "link": "/channels",
          "roles": [
            "admin"
          ]
        },
        {
          "text": "Data and Information\\Timeline",
          "iconKey": "timeline",
          "link": "/timeline",
          "roles": [
            "admin"
          ]
        },
        {
          "text": "Data and Information\\Docs",
          "iconKey": "docs",
          "link": "/docs"
        }
      ]
    },
    "discord-admin": {
      "flowName": "discord-admin"
    },
    "discord-voice": {
      "flowName": "discord-voice"
    },
    "toolcall": {
      "flowName": "toolcall",
      "pollMs": 400,
      "initialDelayMs": 500,
      "registryKey": "status:tool"
    },
    "discord-status-apply": {
      "flow": [
        "discord-status",
        "toolcall"
      ],
      "allowedScopes": [
        "discord",
        "discord-voice"
      ],
      "allowedFlows": [
        "discord",
        "discord-voice"
      ],
      "status": "online",
      "placeholderEnabled": false,
      "placeholderText": "",
      "minUpdateGapMs": 800,
      "mapping": {
        "getImage": "⏳ Generating an image …",
        "getImageSD": "⏳ Generating an image (SD) …",
        "getImageDescription": "⏳ Describing a picture …",
        "getAnimatedPicture": "⏳ Animating a picture …",
        "getVideoFromText": "⏳ Generating a video …",
        "getGoogle": "⏳ Searching with Google …",
        "getWebpage": "⏳ Reading a webpage …",
        "getYoutube": "⏳ Checking YouTube …",
        "getTime": "⏳ Checking the time …",
        "getPDF": "⏳ Generating a PDF …",
        "getText": "⏳ Generating a file …",
        "getHistory": "⏳ Checking history …",
        "getTimeline": "⏳ Checking the timeline …",
        "getToken": "⏳ Generating a token …",
        "getLocation": "⏳ Looking up a location …",
        "getJira": "⏳ Working with Jira …",
        "getConfluence": "⏳ Working with Confluence …",
        "getSubAgent": "⏳ Consulting subagent …"
      }
    },
    "discord-voice-transcribe": {
      "flow": [
        "discord-voice"
      ],
      "pollMs": 1000,
      "silenceMs": 1500,
      "maxCaptureMs": 25000,
      "minVoicedMs": 1000,
      "snrDbThreshold": 3.8,
      "frameMs": 20,
      "startDebounceMs": 600
    },
    "core-ai-completions": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api",
        "bard-label-gen"
      ]
    },
    "core-ai-responses": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api"
      ]
    },
    "core-ai-pseudotoolcalls": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api"
      ]
    },
    "core-ai-roleplay": {
      "flow": [
        "discord-status",
        "discord",
        "discord-voice",
        "api"
      ]
    },
    "discord-voice-tts": {
      "flow": [
        "discord-voice"
      ]
    },
    "discord-add-context": {
