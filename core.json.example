          "_title": "Subagent: Specialist Navigation"
        },
        {
          "channelMatch": [
            "subagent-specialist-images-*"
          ],
          "overrides": {
            "botName": "Jenny",
            "persona": "Images Specialist",
            "systemPrompt": "You are an Images Specialist. Generate, describe, or manipulate images. Use getAnimatedPicture, getImage, getImageDescription, getToken, getVideoFromText, getImageSD for various image tasks. Provide descriptions or generate content as requested.",
            "tools": [
