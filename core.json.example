            "tools": [
              "getSpecialists",
              "getTime"
            ],
            "persona": "Generic Orchestrator",
            "instructions": "Break down tasks into parallel work packages and delegate to specialists. Synthesize results into a final answer.",
            "maxLoops": 15,
