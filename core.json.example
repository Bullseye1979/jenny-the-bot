      "_title": "Channel Overrides"
    },
    "subchannel-config": {
      "flow": [
        "api",
        "discord",
        "discord-admin",
        "webpage"
      ],
      "_title": "Subchannel Config Override"
    },
    "discord-subagent-poll": {
      "enabled": true,
      "pollIntervalMs": 5000,
      "maxJobAgeMs": 86400000,
      "_title": "Async Subagent Delivery - Discord"
    },
    "discord-voice-subagent-poll": {
      "enabled": true,
      "pollIntervalMs": 5000,
      "maxJobAgeMs": 86400000,
      "_title": "Async Subagent Delivery - Discord-Voice (with TTS)"
    },
    "webpage-subagent-poll": {
      "enabled": true,
      "pollIntervalMs": 5000,
      "maxJobAgeMs": 86400000,
      "_title": "Async Subagent Delivery - Webpage (SSE)"
    },
    "bard": {
      "pollIntervalMs": 5000,
      "musicDir": "assets/bard",
      "_title": "Bard Music Scheduler"
    },
    "bard-join": {
      "flow": [
        "discord-admin",
        "discord",
        "webpage",
        "api"
      ],
      "commandPrefix": [
        "/"
      ],
      "_title": "Bard Start/Stop Commands"
    },
    "bard-cron": {
      "flow": [
        "bard-label-gen"
      ],
      "prompt": "You are a music classifier for a D&D tabletop RPG session. Read the transcript and output exactly 6 comma-separated tags describing what is happening right now.\n\nThe 6 positions are fixed and must appear in this exact order:\n1. LOCATION - a physical place from {{LOCATION_TAGS}}. Leave empty if unclear.\n2. SITUATION - the current activity from {{SITUATION_TAGS}}. Leave empty if unclear.\n3. MOOD\n4. MOOD\n5. MOOD\n6. MOOD\nEach mood must come from {{MOOD_TAGS}}. Always output 4 mood values, ordered from strongest fit to weakest fit.\n\nRules:\n- Base the answer only on what is happening in the transcript right now.\n- Use only known tags from the provided lists.\n- Never shift values between positions.\n- Output exactly 6 comma-separated values with no spaces and no explanation.\n\nCurrent labels for reference only: {{CURRENT_LABELS}}\n{{EXAMPLE_LINES}}",
      "_title": "Bard Label Generator"
    },
    "bard-label-output": {
      "flow": [
        "bard-label-gen"
      ],
      "_title": "Bard Label Output"
    },
    "_title": "Module Configuration",
    "webpage-router": {
      "flow": [
        "webpage"
      ],
      "_title": "Flow Router maps endpoints to wo.flow + wo.channelId before core-channel-config",
      "routes": [
        {
          "_title": "Voice Interface",
          "port": 3119,
          "pathPrefix": "/voice",
          "flow": "webpage-voice",
          "channelIdSource": "query:channelId"
        },
        {
          "_title": "Wiki",
          "port": 3117,
          "pathPrefix": "/wiki",
          "flow": "webpage-wiki",
          "channelIdSource": "path:0"
        }
      ]
    },
    "webpage-voice-transcribe-gate": {
      "flow": [
        "webpage"
      ],
      "_title": "Stops pipeline after transcription when wo.transcribeOnly is true (00032)"
    },
    "webpage-voice-input": {
      "flow": [
        "webpage"
      ],
      "_title": "Voice Audio Input Handler (POST /voice/audio, runs before transcription)",
      "port": 3119
    },
    "webpage-voice-add-context": {
      "flow": [
        "webpage"
      ],
      "_title": "Store Voice User Payload to Context DB"
    },
    "webpage-voice": {
      "flow": [
        "webpage"
      ],
      "port": 3119,
      "silenceTimeoutMs": 1500,
      "silenceRmsThreshold": 0.0065,
      "maxDurationMs": 30000,
      "alwaysOnPollMs": 2000,
      "allowedRoles": [
        "member",
        "admin"
      ],
      "channels": [
        {
          "label": "Voice (Jenny)",
          "id": "webpage-voice"
        },
        {
          "label": "Assistant",
          "id": "assistant"
        }
      ],
      "sampleModel": "gpt-4o-mini-transcribe",
      "transcribeApiKey": "OPENAI",
      "clearContextChannels": [
        "assistant"
      ],
      "_title": "Voice Interface (Webpage)"
    },
    "webpage-voice-output": {
      "flow": [
        "webpage"
      ],
      "_title": "Voice Output (Webpage)"
    },
    "webpage-voice-record": {
      "flow": [
        "webpage"
      ],
      "port": 3119,
      "allowedRoles": [
        "member",
        "admin"
      ],
      "clearContextChannels": [
        "assistant"
      ],
      "diarizationSystemPrompt": "You receive numbered transcript segments. Assign each segment to a speaker (Speaker 1, Speaker 2, etc.) based on context and turn-taking patterns. Return ONLY the formatted transcript, one line per segment: \"Speaker X: <text>\". No extra commentary.",
      "_title": "Voice Recording (POST /voice/record)"
    },
    "webpage-keymanager": {
      "__description": "Admin UI for managing API secret aliases. Never store or display real secret values in config. Port 3122, /key-manager. Add 3122 to webpage.ports and webpage-auth.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3122,
      "basePath": "/key-manager",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-manifests": {
      "flow": [
        "webpage"
      ],
      "port": 3126,
      "basePath": "/manifests",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-subagent-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3127,
      "basePath": "/subagents",
      "orchestratorToolName": "getOrchestrator",
      "specialistToolName": "getSpecialists",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-live": {
      "__description": "Live context monitor SPA. Port 3123, /live. Shows real-time transcripts from context table; channels and fields selectable. Add 3123 to webpage.ports and webpage-auth.ports.",
      "flow": [
        "webpage"
      ],
      "port": 3123,
      "basePath": "/live",
      "allowedRoles": [
        "admin"
      ],
      "pollIntervalMs": 2000,
      "messageLimit": 300
    },
    "webpage-graph-auth": {
      "__description": "Microsoft Graph delegated OAuth2. Users connect their MS account here. Tokens stored in graph_tokens DB table. Port 3124, /graph-auth.",
      "flow": [
        "webpage"
      ],
      "port": 3124,
      "auth": {
        "tenantId": "MS_TENANT_ID",
        "clientId": "MS_CLIENT_ID",
        "clientSecret": "MS_CLIENT_SECRET",
        "redirectUri": "https://jenny.ralfreschke.de/graph-auth/callback",
        "scope": "offline_access User.Read Mail.ReadWrite Mail.Send Files.ReadWrite.All Sites.ReadWrite.All"
      }
    },
    "cron-graph-token-refresh": {
      "__description": "Refreshes expiring Microsoft Graph tokens every 5 minutes.",
      "flow": [
        "cron-graph-token-refresh"
      ],
      "auth": {
        "tenantId": "MS_TENANT_ID",
        "clientId": "MS_CLIENT_ID",
        "clientSecret": "MS_CLIENT_SECRET"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-spotify-auth": {
      "__description": "Spotify delegated OAuth2. Users connect their Spotify account here. Tokens stored in spotify_tokens DB table. Port 3125, /spotify-auth.",
      "flow": [
        "webpage"
      ],
      "port": 3125,
      "auth": {
        "clientId": "SPOTIFY_CLIENT_ID",
        "clientSecret": "SPOTIFY_CLIENT_SECRET",
        "redirectUri": "https://jenny.ralfreschke.de/spotify-auth/callback",
        "scope": "user-read-playback-state user-modify-playback-state user-read-currently-playing playlist-read-private playlist-read-collaborative playlist-modify-public playlist-modify-private"
      }
    },
    "cron-spotify-token-refresh": {
      "__description": "Refreshes expiring Spotify tokens every 5 minutes.",
      "flow": [
        "cron-spotify-token-refresh"
      ],
      "auth": {
        "clientId": "SPOTIFY_CLIENT_ID",
        "clientSecret": "SPOTIFY_CLIENT_SECRET"
      },
      "refreshBufferMinutes": 10
    },
    "webpage-channel-config-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3129,
      "basePath": "/channels",
      "allowedRoles": [
        "admin"
      ]
    },
    "webpage-oauth-manager": {
      "flow": [
        "webpage"
      ],
      "port": 3130,
      "basePath": "/oauth",
      "roles": [
        "admin"
      ]
    },
    "webpage-oauth-connections": {
      "flow": [
        "webpage"
      ],
      "port": 3131,
      "redirectUriBase": "https://jenny.ralfreschke.de/connections",
      "roles": [
        "member",
        "admin"
      ]
    },
    "webpage-oauth-exposure": {
      "flow": [
        "webpage"
      ],
      "port": 3132,
      "toolName": "getOauthProviders",
      "roles": [
        "admin"
      ]
    },
    "webpage-bearer-exposure": {
      "flow": [
        "webpage"
      ],
      "port": 3133,
      "toolName": "getApiBearers",
      "roles": [
        "admin"
      ]
    },
    "mcp": {
      "defaultChannelId": "mcp",
      "stdio": false,
      "http": {
        "enabled": true,
        "port": 3100,
        "path": "/mcp"
      }
    }
  }
}
