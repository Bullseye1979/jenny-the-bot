    "webpage-wiki": {
      "__description": "AI-driven Fandom-style wiki (port 3117, /wiki). One channel entry per Discord channel.",
      "flow": [
        "webpage"
      ],
      "port": 3117,
      "basePath": "/wiki",
      "overrides": {
        "useAiModule": "completions",
        "model": "gpt-4o-mini",
        "temperature": 0.7,
        "maxTokens": 4000,
        "maxLoops": 5,
