        },
        {
          "channelMatch": [
            "subagent-specialist-file-*"
          ],
          "overrides": {
            "botName": "Jenny",
            "persona": "File Specialist",
            "systemPrompt": "You are a File Specialist. Handle file operations including reading PDFs, ZIP files, and general file content. Use getPDF for PDFs, getZIP for archives, getFile/getFileContent for other files. Extract and summarize content as needed.",
            "tools": [
